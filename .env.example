# Copy to .env for local Postgres (see docker-compose.yml). Unset, the app and
# tests fall back to a local SQLite file — no Docker needed.
DATABASE_URL=postgresql+psycopg://marketplace:marketplace@localhost:5432/marketplace

QUOTE_TTL_MINUTES=5
OFFER_TTL_MINUTES=2

# Payments — leave unset to use the built-in deterministic fake provider.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# CURRENCY=usd
# PAYMENT_TTL_MINUTES=30
# ONBOARDING_RETURN_URL=https://your-app.example/onboarded

# Auth — sessions are DB-backed; the admin account is seeded at startup, and a
# changed ADMIN_PASSWORD is rotated in on the next restart (existing admin
# sessions are revoked).
# ADMIN_EMAIL=ops@your-app.example
# ADMIN_PASSWORD=change-me
# SESSION_TTL_HOURS=72
# BASE_URL is your app's own frontend, not this API: verification/reset links
# are BASE_URL/verify?token=... and BASE_URL/password-reset/confirm?token=...,
# and the API has no GET handlers for those paths — whatever serves BASE_URL
# must relay the token to the POST endpoints.
# BASE_URL=https://your-app.example

# Notifications - outbox drained in-process; SMTP unset -> console adapter (logs).
# NOTIFY_DRAIN_SECONDS=5
# NOTIFY_MAX_ATTEMPTS=5
# SWEEP_INTERVAL_SECONDS=60
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_STARTTLS=true
# MAIL_FROM=noreply@your-app.example
