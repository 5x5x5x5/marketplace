# Copy to .env for local Postgres (see docker-compose.yml). Unset, the app and
# tests fall back to a local SQLite file — no Docker needed.
DATABASE_URL=postgresql+psycopg://marketplace:marketplace@localhost:5432/marketplace

# MUST be a strong random value in production — signs the pilot auth tokens.
MARKETPLACE_SECRET=change-me-in-production

QUOTE_TTL_MINUTES=5
OFFER_TTL_MINUTES=2
TOKEN_TTL_HOURS=24

# Payments — leave unset to use the built-in deterministic fake provider.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# CURRENCY=usd
# PAYMENT_TTL_MINUTES=30
# ONBOARDING_RETURN_URL=https://your-app.example/onboarded
